{
  "files.associations": {
    "**/java/**/resources/**/*.html": "qute-html",
    "**/!java/**/templates/*.html": "django-html",
    "**/!/java/**/templates/*": "django-txt"
  },
  "yaml.schemas": {
    "file:///home/bradley/.vscode-oss/extensions/continue.continue-1.2.22-linux-x64/config-yaml-schema.json": [
      ".continue/**/*.yaml"
    ]
  },
  "[django-html]": {
    "editor.defaultFormatter": "monosans.djlint",
    "editor.formatOnSave": true,
    "djlint.profile": "django"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "vim.handleKeys": {
    "<C-d>": true,
    "<C-s>": false,
    "<C-z>": false,
    "<C-p>": false,
    "<C-w>": false,
    "gd": true
  },
  "vim.insertModeKeyBindingsNonRecursive": [
    {
      "before": [
        "j",
        "j"
      ],
      "after": [
        "<Esc>"
      ]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "]",
        "d"
      ],
      "commands": [
        "editor.action.marker.next"
      ]
    },
    {
      "before": [
        "[",
        "d"
      ],
      "commands": [
        "editor.action.marker.prev"
      ]
    },
    {
      "before": [
        "g",
        "d"
      ],
      "commands": [
        "editor.action.revealDefinition"
      ]
    },
    {
      "before": [
        "g",
        "]"
      ],
      "commands": [
        "editor.action.marker.next"
      ]
    },
    {
      "before": [
        "g",
        "["
      ],
      "commands": [
        "editor.action.marker.prev"
      ]
    },
    {
      "before": [
        "<leader>",
        "g",
        "]"
      ],
      "commands": [
        "editor.action.marker.nextInFiles"
      ]
    },
    {
      "before": [
        "<leader>",
        "g",
        "["
      ],
      "commands": [
        "editor.action.marker.prevInFiles"
      ]
    },
    {
      "before": [
        "<leader>",
        "r",
        "n"
      ],
      "commands": [
        "editor.action.rename"
      ]
    }
  ],
  "vim.leader": "<Space>",
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "search.exclude": {
    "**/.venv": true
  },
  "emmet.triggerExpansionOnTab": true,
  "emmet.includeLanguages": {
    "html.erb": "html",
    "django-html": "html",
    "qute-html": "html",
    "razor": "html"
  },
  "djls.djangoSettingsModule": "config.settings",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "bootstrapIntelliSense": {
    "enable": true,
    "bsVersion": "5.3.8",
    "useLocalFile": false,
    "cssFilePath": "",
    "languageSupport": [
      "django-html"
    ],
    "enableHover": true,
    "enableColorPreview": true,
    "sortOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "qute.validation.enabled": true
}